<Window x:Class="DijkstraSubway.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DijkstraSubway"
      mc:Ignorable="d"
   Title="지하철 최단경로 검색" Height="800" Width="1000" FontFamily="Malgun Gothic">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
       Background="{TemplateBinding Background}" 
     BorderBrush="#999999" 
    BorderThickness="1,1,1,0" 
           CornerRadius="4,4,0,0" 
      Padding="12,6"
                 Margin="2,0">
                            <ContentPresenter x:Name="ContentSite" 
       VerticalAlignment="Center" 
         HorizontalAlignment="Center"
             ContentSource="Header"
           TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Panel.ZIndex" Value="100"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,0"/>
                                <Setter TargetName="Border" Property="Margin" Value="2,0,2,-1"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Top" Margin="20">
            <TextBlock Text="1~9호선 지하철 최단경로 검색" FontSize="24" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="출발점" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TabControl x:Name="StartTabControl" Height="280">
                        <TabItem Header="1호선" Background="#0052A4" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="1호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="StartLine1ListBox" SelectionChanged="StartLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="2호선" Background="#00A84D" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="2호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="StartLine2ListBox" SelectionChanged="StartLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="3호선" Background="#EF7C1C" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="3호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="StartLine3ListBox" SelectionChanged="StartLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="4호선" Background="#00A5DE" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="4호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="StartLine4ListBox" SelectionChanged="StartLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="5호선" Background="#996CAC" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="5호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="StartLine5ListBox" SelectionChanged="StartLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="6호선" Background="#CD7C2F" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="6호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="StartLine6ListBox" SelectionChanged="StartLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="7호선" Background="#747F00" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="7호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="StartLine7ListBox" SelectionChanged="StartLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="8호선" Background="#E6186C" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="8호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="StartLine8ListBox" SelectionChanged="StartLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="9호선" Background="#BDB092" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="9호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="StartLine9ListBox" SelectionChanged="StartLineListBox_SelectionChanged"/>
                        </TabItem>
                    </TabControl>
                    <TextBox x:Name="StartStationTextBox" Height="40" FontSize="14" Padding="10" Margin="0,5,0,0" IsReadOnly="True" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="도착점" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TabControl x:Name="EndTabControl" Height="280">
                        <TabItem Header="1호선" Background="#0052A4" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="1호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="EndLine1ListBox" SelectionChanged="EndLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="2호선" Background="#00A84D" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="2호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="EndLine2ListBox" SelectionChanged="EndLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="3호선" Background="#EF7C1C" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="3호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="EndLine3ListBox" SelectionChanged="EndLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="4호선" Background="#00A5DE" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="4호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="EndLine4ListBox" SelectionChanged="EndLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="5호선" Background="#996CAC" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="5호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="EndLine5ListBox" SelectionChanged="EndLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="6호선" Background="#CD7C2F" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="6호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="EndLine6ListBox" SelectionChanged="EndLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="7호선" Background="#747F00" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="7호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="EndLine7ListBox" SelectionChanged="EndLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="8호선" Background="#E6186C" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="8호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="EndLine8ListBox" SelectionChanged="EndLineListBox_SelectionChanged"/>
                        </TabItem>
                        <TabItem Header="9호선" Background="#BDB092" Foreground="White">
                            <TabItem.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="9호선" Foreground="White" FontWeight="Bold"/>
                                </DataTemplate>
                            </TabItem.HeaderTemplate>
                            <ListBox x:Name="EndLine9ListBox" SelectionChanged="EndLineListBox_SelectionChanged"/>
                        </TabItem>
                    </TabControl>
                    <TextBox x:Name="EndStationTextBox" Height="40" FontSize="14" Padding="10" Margin="0,5,0,0" IsReadOnly="True" VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Button x:Name="SearchButton" Content="경로 검색" Height="40" FontSize="14" Margin="0,15,0,0" Click="SearchButton_Click" Background="#007ACC" Foreground="White"/>
        </StackPanel>

        <Border x:Name="ResultPanel" VerticalAlignment="Bottom" Margin="20" Background="White" 
           BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="8" Padding="15"
          MaxHeight="250" Opacity="0">
            <Border.Effect>
                <DropShadowEffect Color="#999999" BlurRadius="10" ShadowDepth="3" Opacity="0.3"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ResultContent">
                    <TextBlock x:Name="ResultHeader" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ItemsControl x:Name="ResultItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Margin="0,2" Padding="8,5" Background="#F9F9F9" 
             CornerRadius="4" BorderThickness="0,0,0,2">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{Binding LineColor}"/>
                                        </Border.BorderBrush>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" 
                   Margin="0,0,10,0" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding LineColor}"/>
                                                </Border.Background>
                                            </Border>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="{Binding StationName}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding LineText}" FontSize="11" Foreground="#666666" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="[환승]" FontSize="11" FontWeight="Bold" 
                  Foreground="#FF6B35" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTransfer}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="↓" FontSize="14" Foreground="#999999" 
                         HorizontalAlignment="Center" Margin="0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowArrow}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="ResultSummary" FontSize="12" Foreground="#666666" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>